{
  "name": "auth-api",
  "version": "2.0.0",
  "description": "Property Listing API with Supabase",
  "main": "dist/supabaseServer.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/supabaseServer.js",
    "start:typeorm": "npm run build && node dist/server.js",
    "dev": "tsc && node --watch dist/supabaseServer.js",
    "dev:typeorm": "tsc && node --watch dist/server.js",
    "setup-db": "node scripts/setup-db.js",
    "test": "node test-api.js"
  },
  "keywords": [
    "auth",
    "jwt",
    "registration",
    "login"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.86.2",
    "aws-sdk": "^2.1692.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "typescript": "^5.9.3"
  }
}
